# === LLM & TRACING ===
# Groq API (https://console.groq.com)
GROQ_API_KEY=gsk_52e7r...

# Tavily search (https://app.tavily.com)
TAVILY_API_KEY=tvly-...

# LangSmith tracing (optional, https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...

# === MODEL CONFIG ===
MEMORY_MODEL=groq/compound-mini
TITLE_MODEL=groq/compound-mini
SUMMARIZER_MODEL=groq/compound-mini

# === AUTH (Clerk) ===
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhooks → Endpoints → select endpoint → Signing secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_... # starts with whsec_

# === DATABASES ===
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require&connection_limit=10
REDIS_URL=redis://redis:6379/0 

# === OBSERVABILITY ===
# Any random secret you generate
PROMETHEUS_SECRET=8b0a7f3c9e2d5e1f8c9b7a4e6d2c1a9b0 # example

# === CLIENT ===
CLIENT_URL=http://localhost:5173     # where you run Vite server
