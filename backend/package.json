{
  "name": "@app/backend",
  "version": "1.0.0",
  "description": "sleek ai backend",
  "main": "src/app.ts",
  "type": "module",
  "scripts": {
    "dev": "pnpm run bun:dev",
    "start": "pnpm run bun:start",
    "bun:dev": "bun --watch src/app.ts",
    "node:dev": "tsx watch src/app.ts",
    "bun:start": "bun src/app.ts",
    "node:start": "npm run build && node dist/app.js",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "lint": "eslint --ext .ts src"
  },
  "keywords": [],
  "author": "https://github.com/sunjay-dev/",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@app/shared": "workspace:*",
    "@clerk/backend": "^2.33.0",
    "@hono/clerk-auth": "^3.1.0",
    "@langchain/core": "^1.1.30",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/groq": "^1.1.4",
    "@langchain/langgraph-checkpoint-redis": "^1.0.2",
    "@langchain/openrouter": "^0.1.5",
    "@langchain/pinecone": "^1.0.1",
    "@langchain/tavily": "^1.2.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bullmq": "^5.70.2",
    "cloudinary": "^2.9.0",
    "hono": "^4.12.5",
    "langchain": "^1.2.29",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "prisma": "^7.4.2"
  }
}