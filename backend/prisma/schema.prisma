generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  runtime         = "bun"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  clerkId        String          @unique
  firstName      String?
  email          String?
  lastName       String?
  imageUrl       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  chats          Chat[]
  userPreference UserPreference?
  userMemories   UserMemory[]
}

model UserMemory {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model UserPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique
  nickname           String?
  occupation         String?
  about              String?
  customInstructions String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
}

enum RagStatus {
  IDLE
  PROCESSING
  COMPLETED
  FAILED
}

model Chat {
  id        String    @id @default(uuid())
  userId    String
  title     String?
  isRag     Boolean   @default(false)
  ragStatus RagStatus @default(IDLE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [clerkId])
  messages  Message[]
}

model Message {
  id           String        @id @default(uuid())
  chatId       String
  text         String
  createdAt    DateTime      @default(now())
  role         MessageRole   @default(USER)
  chat         Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  messageFiles MessageFile[]

  @@index([chatId, createdAt])
}

model MessageFile {
  id        String @id @default(uuid())
  messageId String

  fileUrl  String
  fileName String
  fileType String

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model checkpoint_blobs {
  thread_id     String
  checkpoint_ns String @default("")
  channel       String
  version       String
  type          String
  blob          Bytes?

  @@id([thread_id, checkpoint_ns, channel, version])
}

model checkpoint_migrations {
  v Int @id
}

model checkpoint_writes {
  thread_id     String
  checkpoint_ns String  @default("")
  checkpoint_id String
  task_id       String
  idx           Int
  channel       String
  type          String?
  blob          Bytes

  @@id([thread_id, checkpoint_ns, checkpoint_id, task_id, idx])
}

model checkpoints {
  thread_id            String
  checkpoint_ns        String  @default("")
  checkpoint_id        String
  parent_checkpoint_id String?
  type                 String?
  checkpoint           Json
  metadata             Json    @default("{}")

  @@id([thread_id, checkpoint_ns, checkpoint_id])
}
