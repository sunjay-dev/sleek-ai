{
  "name": "gen-ai",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel run dev",
    "start": "pnpm -r --parallel run start",
    "lint:backend": "eslint backend/src --ext .ts --fix",
    "lint:frontend": "eslint frontend/src --ext .ts,.tsx --fix"
  },
  "author": "https://github.com/sunjay-dev/",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "lint-staged": {
    "backend/src/**/*.ts": [
      "pnpm --filter @app/backend run lint:backend"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "pnpm --filter @app/frontend run lint:frontend"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
